{
  "name": "@treatink/sdk",
  "version": "0.0.0",
  "description": "Embeddable Treatink product personalization: a native modal designer + a publishable-key API client.",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:golden": "vitest run test/golden",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test test/a11y",
    "size": "size-limit",
    "check:no-secret": "node scripts/check-no-secret.mjs",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run size"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "heic2any": "^0.0.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@napi-rs/canvas": "^0.1.55",
    "@playwright/test": "^1.47.2",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@types/node": "^20.16.0",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^9.11.0",
    "prettier": "^3.3.3",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.7.0",
    "vitest": "^2.1.1"
  },
  "size-limit": [
    {
      "name": "loader",
      "path": "dist/index.js",
      "limit": "15 KB",
      "gzip": true
    },
    {
      "name": "designer chunk",
      "path": "dist/designer-*.js",
      "limit": "150 KB",
      "gzip": true
    }
  ]
}
